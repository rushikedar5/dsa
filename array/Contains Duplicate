class Solution {
    public boolean hasDuplicate(int[] nums) {
        int n = nums.length;
        HashSet<Integer> map = new HashSet<>();

        for(int i=0; i<n; i++){
            int current = nums[i];
            if(map.contains(current)) {
                return true;
            }
            map.add(nums[i]);       
        }

        return false;
    }
}
